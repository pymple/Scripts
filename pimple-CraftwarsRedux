    local args = { "meteor", { damage, head } }
    local success = pcall(function() remoteFunc:InvokeServer(unpack(args)) end)
    return success
end

-- Helper function to update toggle UI state
local function UpdateToggleState(toggle, value)
    if not toggle then return end
    
    pcall(function()
        -- Try multiple common method names used by UI libraries
        if toggle.Set then
            toggle:Set(value)
        elseif toggle.SetValue then
            toggle:SetValue(value)
        elseif toggle.SetState then
            toggle:SetState(value)
        elseif toggle.UpdateValue then
            toggle:UpdateValue(value)
        elseif toggle.Value ~= nil then
            toggle.Value = value
        elseif toggle.State ~= nil then
            toggle.State = value
        end
        
        -- Some libraries need an explicit refresh/update call
        if toggle.Refresh then
            toggle:Refresh()
        elseif toggle.Update then
            toggle:Update()
        end
    end)
end

