-- Keybind input handler
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or IsTyping() then return end
    
    if input.KeyCode == Flags.SwingKeybind then
        ToggleAutoSwing()
    elseif input.KeyCode == Flags.AbilityKeybind then
        ToggleAutoAbilities()
    end
end)

RunService.RenderStepped:Connect(function(DeltaTime)
    CooldownTimer = CooldownTimer + DeltaTime
    BiomeCheckTimer = BiomeCheckTimer + DeltaTime
    CutsceneCheckTimer = CutsceneCheckTimer + DeltaTime
    MeteorTimer = MeteorTimer + DeltaTime
    SwingTimer = SwingTimer + DeltaTime
    AbilityTimer = AbilityTimer + DeltaTime
    LastAutoSave = LastAutoSave + DeltaTime
    
    if Flags.AutoSaveEnabled and LastAutoSave >= AutoSaveInterval then
        LastAutoSave = 0
        task.spawn(function()
            SaveConfig()
        end)
    end
    
    if CutsceneCheckTimer >= 1 then BossDetected = DetectBossPresence() end
    
    if Flags.AutoSwing and SwingTimer >= Flags.SwingCooldown then
        SwingTimer = 0
        PerformSwingAttack()
    end
    
    if Flags.AutoAbilities and AbilityTimer >= Flags.AbilityCooldown then
        AbilityTimer = 0
        PerformAbilities()
    end
    
    if Flags.AutoMeteor and MeteorTimer >= Flags.MeteorCooldown then
        MeteorTimer = 0
        local weapon, remoteFunc = GetEquippedMeteorWeapon()
        if weapon and remoteFunc then
            local enemy = GetNearestEnemy()
            if enemy then FireMeteor(remoteFunc, enemy) end
        end
    end
    
    if Flags.AutoSkipCutscene and BossDetected and CutsceneCheckTimer >= Flags.CutsceneCheckInterval then
        CutsceneCheckTimer = 0
        local inCutscene = DetectBossCutscene()
        if inCutscene and not IsInCutscene then
            IsInCutscene = true
            task.spawn(function()
                task.wait(0.1)
                SkipBossCutscene()
                task.wait(0.2)
                if DetectBossCutscene() then SkipBossCutscene() end
            end)
        elseif not inCutscene then IsInCutscene = false end
    end
    
    if Flags.AutoBiomeLock and BiomeCheckTimer >= Flags.BiomeCheckInterval then
        BiomeCheckTimer = 0
        SummonBiome(Flags.TargetBiome)
    end
    
    if not Flags.Enabled then return end
    local cooldown = tonumber(Flags.AttackCooldown) or 0.5
    if CooldownTimer < cooldown then return end
    local weapon = GetWeapon()
    if not weapon then return end
    local remoteFunc = weapon:FindFirstChild("RemoteFunction")
    if not remoteFunc then return end
    local hitValue = GetDamageValue()
    
    if Flags.AutoEnemies then
        local enemies = GetAllEnemies()
        for _, model in ipairs(enemies) do
            local humanoid = model:FindFirstChild("Humanoid")
            if humanoid and IsUsableHealth(humanoid.Health) then
                pcall(function() remoteFunc:InvokeServer("hit", { humanoid, hitValue }) end)
            end
        end
    end
    
    if Flags.AutoMines and type(Flags.MineTargets) == "table" then
        for mineName, isSelected in pairs(Flags.MineTargets) do
            if isSelected and type(mineName) == "string" then
                local mineFolder = workspace:FindFirstChild(mineName)
                if mineFolder then
                    for _, child in ipairs(mineFolder:GetChildren()) do
                        local ore = child:FindFirstChild("Ore")
                        if ore then
                            local oreHealth = GetOreHealth(ore)
                            if oreHealth == nil or IsUsableHealth(oreHealth) then
                                pcall(function() remoteFunc:InvokeServer("hit", { ore, hitValue }) end)
                            end
                        end
                    end
                end
            end
        end
    end
    CooldownTimer = 0
end)

