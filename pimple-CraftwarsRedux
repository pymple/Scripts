local function GetAllEquippedWeapons()
    local weapons = {}
    local charactersFolder = workspace:FindFirstChild("Characters")
    if not charactersFolder then return weapons end
    local playerCharFolder = charactersFolder:FindFirstChild(LocalPlayer.Name)
    if not playerCharFolder then return weapons end
    
    for _, item in ipairs(playerCharFolder:GetChildren()) do
        local remote = nil
        local remoteType = nil
        
        local remoteFunc = item:FindFirstChild("RemoteFunction")
        if remoteFunc then
            remote = remoteFunc
            remoteType = "RemoteFunction"
        end
        
        local remoteEvent = item:FindFirstChild("RemoteEvent")
        if remoteEvent then
            remote = remoteEvent
            remoteType = "RemoteEvent"
        end
        
        for _, child in ipairs(item:GetChildren()) do
            if string.find(child.Name, "Remote") and (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")) then
                remote = child
                remoteType = child.ClassName
                break
            end
        end
        
        if remote then
            table.insert(weapons, {
                weapon = item,
                remote = remote,
                remoteType = remoteType,
                name = item.Name
            })
        end
    end
    
    return weapons
end

