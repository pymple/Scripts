    CachedWeapon = nil
    for _, child in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if child:FindFirstChild("SwordControl") and child:FindFirstChild("RemoteFunction") then
            CachedWeapon = child
            return CachedWeapon
        end
    end
    return nil
end

