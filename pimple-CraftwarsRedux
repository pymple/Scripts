        if not remoteFunc then return end
        local count = 0
        local enemies = GetAllEnemies()
        for _, model in ipairs(enemies) do
            local humanoid = model:FindFirstChild("Humanoid")
            if humanoid then
                local health = humanoid.Health
                if type(health) == "number" and health == health and math.abs(health) ~= math.huge and health > 1 then
