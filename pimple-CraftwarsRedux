local function CanUseFileSystem()
    local success = pcall(function()
        return writefile and readfile and isfile
    end)
    return success and writefile and readfile and isfile
end

local function SaveConfig()
    if not CanUseFileSystem() then
        warn("[pimple] File system not available - cannot save config")
        return false
    end
    
    local configData = {
        version = CONFIG_VERSION,
        timestamp = os.time(),
        settings = {}
    }
    
    for _, key in ipairs(SaveableKeys) do
        local value = Flags[key]
        if key == "DamageValue" then
        elseif type(value) == "table" then
            configData.settings[key] = value
        elseif value ~= nil then
            configData.settings[key] = value
        end
    end
    
    local success, err = pcall(function()
        local jsonString = HttpService:JSONEncode(configData)
        writefile(CONFIG_FILE, jsonString)
    end)
    
    if success then
        print("[pimple] Config saved successfully!")
        return true
    else
        warn("[pimple] Failed to save config:", err)
        return false
    end
end

local function LoadConfig()
    if not CanUseFileSystem() then
        warn("[pimple] File system not available - using defaults")
        return false
    end
    
    if not isfile(CONFIG_FILE) then
        print("[pimple] No config file found - using defaults")
        return false
    end
    
    local success, result = pcall(function()
        local jsonString = readfile(CONFIG_FILE)
        return HttpService:JSONDecode(jsonString)
    end)
    
    if not success or not result then
        warn("[pimple] Failed to load config:", result)
        return false
    end
    
    if result.version ~= CONFIG_VERSION then
        print("[pimple] Config version mismatch - some settings may reset")
    end
    
    local settings = result.settings or {}
    for key, value in pairs(settings) do
        if Flags[key] ~= nil then
            if type(value) == type(Flags[key]) or (type(Flags[key]) == "number" and type(value) == "number") then
                Flags[key] = value
            end
        end
    end
    
    if Flags.DamageInput then
        Flags.DamageValue = ParseDamage(Flags.DamageInput)
    end
    
    print("[pimple] Config loaded successfully!")
    print("[pimple] Last saved:", os.date("%Y-%m-%d %H:%M:%S", result.timestamp or 0))
    return true
end

