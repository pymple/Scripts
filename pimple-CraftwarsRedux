function ParseDamage(input)
    if not input or input == "" then return math.huge end
    local str = tostring(input):lower():gsub(",", ""):gsub(" ", "")
    if str == "inf" or str == "infinite" or str == "max" then return math.huge end
    local num, suffix = str:match("^([%d%.]+)([kmbt]?)$")
    if num then
        local value = tonumber(num)
        if value then
            if suffix == "k" then value = value * 1000
            elseif suffix == "m" then value = value * 1000000
            elseif suffix == "b" then value = value * 1000000000
            elseif suffix == "t" then value = value * 1000000000000
            end
            return value
        end
    end
    local direct = tonumber(str)
    if direct then return direct end
    return math.huge
end

