local function DetectBossPresence()
    for _, model in ipairs(workspace:GetChildren()) do
        if model:IsA("Model") then
            local humanoid = model:FindFirstChild("Humanoid")
            local enemyMain = model:FindFirstChild("EnemyMain") or model:FindFirstChild("BossMain")
            if humanoid and (enemyMain or IsSpecialBoss(model)) then
                local modelName = model.Name:lower()
                for _, bossName in ipairs(BossNames) do
                    if string.find(modelName, bossName:lower()) then return true end
                end
                if humanoid.MaxHealth and humanoid.MaxHealth > 100000 then return true end
            end
        end
    end
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in ipairs(playerGui:GetDescendants()) do
            if gui:IsA("TextLabel") then
                local text = gui.Text or ""
                for _, bossName in ipairs(BossNames) do
                    if string.find(text, bossName) then return true end
                end
                if string.match(text, "%[.+%]:") then return true end
            end
        end
    end
    return false
end

local function SkipBossCutscene()
    local remote = GetBossCutsceneRemote()
    if remote then
        local success, err = pcall(function() remote:FireServer("Skip") end)
        if success then IsInCutscene = false else warn("[pimple] Failed to skip cutscene:", err) end
        return success
    end
    return false
end

local function DetectBossCutscene()
    if not BossDetected then return false end
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    for _, gui in ipairs(playerGui:GetDescendants()) do
        if gui:IsA("TextLabel") or gui:IsA("TextButton") then
            local textLower = (gui.Text or ""):lower()
            if (string.find(textLower, "tap") and string.find(textLower, "skip")) or
               (string.find(textLower, "skip") and gui.Visible and gui:IsA("TextButton")) then
                return true
            end
        end
    end
    local cutsceneGui = playerGui:FindFirstChild("CutsceneGui") or playerGui:FindFirstChild("BossCutscene")
        or playerGui:FindFirstChild("Cutscene") or playerGui:FindFirstChild("CutsceneFrame")
    if cutsceneGui and cutsceneGui.Enabled ~= false then return true end
    local inCutscene = LocalPlayer:GetAttribute("InCutscene") or LocalPlayer:GetAttribute("Cutscene")
    if inCutscene == true then return true end
    return false
end

