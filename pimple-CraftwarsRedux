local function FireRemote(weaponData, abilityName)
    if not weaponData or not weaponData.remote then return false end
    
    local args = { abilityName }
    local success = false
    
    if weaponData.remoteType == "RemoteEvent" or weaponData.remote:IsA("RemoteEvent") then
        success = pcall(function()
            weaponData.remote:FireServer(unpack(args))
        end)
    else
        success = pcall(function()
            weaponData.remote:InvokeServer(unpack(args))
        end)
    end
    
    return success
end

